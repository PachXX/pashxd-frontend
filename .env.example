# Backend API base URL.
# Local dev:   http://127.0.0.1:8000
# Production:  the Cloud Run service URL (or https://api.pashx.com once
#              the custom domain is mapped). Set this in Vercel too.
VITE_API_URL=http://127.0.0.1:8000

# Firebase (client-side config — these values are public by design: they
# identify the project to Firebase, they are not secrets, and they ship
# inside every Firebase web app's JS bundle. Access is controlled by
# Firebase Security Rules / backend auth, not by hiding these values.
# Get them from: Firebase console -> Project settings -> Your apps -> Web app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
